class _LRUPosterCache:
    """Caché de PhotoImage con límite de 200 entradas (LRU eviction).
    Sin límite, con 500+ títulos la RAM crecería indefinidamente."""
    _MAX = 200

    def __init__(self):
        self._od: OrderedDict = OrderedDict()

    def get(self, key, default=None):
        if key in self._od:
            self._od.move_to_end(key)
            return self._od[key]
        return default

    def __setitem__(self, key, value):
        self._od[key] = value
        self._od.move_to_end(key)
        if len(self._od) > self._MAX:
            self._od.popitem(last=False)

    def __getitem__(self, key):
        if key in self._od:
            self._od.move_to_end(key)
            return self._od[key]
        raise KeyError(key)

    def __contains__(self, key):
        return key in self._od

    def __len__(self):
        return len(self._od)


_poster_mem = _LRUPosterCache()

