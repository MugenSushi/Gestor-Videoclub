                 ).pack(side="left", padx=(0, 10))

        year = data.get("Year", "")
        tk.Label(hdr, text=f"{title}  {year}",
                 bg=C["surface"], fg=C["text"],
                 font=(FONT_FAMILY, 12, "bold"),
                 wraplength=480, justify="left"
                 ).pack(side="left", fill="x", expand=True)

        btn_txt   = "✅ En biblioteca" if is_dup else "➕ Añadir"
        btn_color = C["border"] if is_dup else C["accent"]
        btn = tk.Button(hdr, text=btn_txt, bg=btn_color, fg="white",
                        font=(FONT_FAMILY, 9, "bold"), relief="flat",
                        padx=10, pady=3, cursor="hand2",
                        state="disabled" if is_dup else "normal",
                        command=lambda d=data: self._add_result(d))
        btn.pack(side="right")
        data["_btn"] = btn

        # Fila detalles: rating · géneros
        details = []
        rating_str = data.get("imdbRating", "")
        if rating_str and rating_str not in ("0", "0.0", ""):
            details.append(f"★ {rating_str}")
        genre = data.get("Genre", "")
        if genre and genre != "N/A":
            details.append(genre[:50])
