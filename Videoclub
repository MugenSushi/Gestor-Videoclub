    def _export_dash(self, db: Database, fmt: str):
        ext  = {"csv": "csv", "json": "json", "txt": "txt"}.get(fmt, "csv")
        uid  = self.active_user_id
        user = self.active_user
        path = filedialog.asksaveasfilename(
            defaultextension=f".{ext}",
            filetypes=[(ext.upper(), f"*.{ext}"), ("Todos", "*.*")],
            initialfile=f"videoclub_{user}.{ext}"
        )
        if not path:
            return
        try:
            if fmt == "csv":
                db.export_csv(path, uid)
            elif fmt == "json":
                db.export_json(path, uid)
            else:
                db.export_txt(path, uid, self._statuses)
            n = db.count_items(uid)
            show_toast(self, f"{n} títulos exportados ({ext.upper()})")
            messagebox.showinfo("Exportado", f"Guardado en:\n{path}", parent=self)
        except Exception as e:
            messagebox.showerror("Error", str(e), parent=self)

