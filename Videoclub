               f"&apikey={key}&plot=full")
        data = requests.get(url, timeout=8).json()
        if data.get("Response") == "True":
            return data
        log.warning(f"OMDb: {title} → {data.get('Error','')}")
    except Exception as e:
        log.error(f"fetch_omdb: {e}")
