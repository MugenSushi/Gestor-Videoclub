# 17. RECOMMENDATION ENGINE
# ══════════════════════════════════════════════════════════════

class RecommendationEngine:
    def __init__(self, db: Database):
        self.db = db

    def recommend(self, user_id: int, genre_filter: str = None) -> dict | None:
        items = self.db.get_items(user_id=user_id)
        if not items:
            return None
        statuses = self.db.get_all_statuses(user_id)
        unseen = [i for i in items
                  if statuses.get(i["title"], STATUS_NONE) == STATUS_NONE]
        pool = unseen if unseen else list(items)
        if genre_filter:
            filtered = [i for i in pool if genre_filter in (i["genres"] or "")]
            if filtered:
                pool = filtered
        return dict(random.choice(pool))


