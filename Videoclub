class UserPickerWindow(tk.Toplevel):
    """
    Gestión de perfiles: seleccionar, crear, renombrar y eliminar.

    BUG FIX: destroy() se llama ANTES de on_select() para liberar el
    grab_set() antes de que refresh() reconstruya la ventana principal.
    Sin esto el redibujado quedaba bloqueado y las cards no se actualizaban.
    """
