class VideoclubApp(tk.Tk):
    def __init__(self):
        super().__init__()
        self.title(f"{APP_NAME} v{VERSION}")
        self.configure(bg=C["bg"])
        self.minsize(1000, 650)
        self.state("zoomed")

        self.db             = Database()
        self.engine         = RecommendationEngine(self.db)
        self.active_user    = "Default"
        self.active_user_id = self.db.get_user_id("Default")
        self.search_var     = tk.StringVar()
        self.filter_type    = tk.StringVar(value="all")
        self.status_filter  = tk.StringVar(value="all")
        self.sort_order     = tk.StringVar(value="title")
        self.genre_filter   = tk.StringVar(value="")
        self._cards         = []
        self._page          = 0
        self._all_items     = []
        self._statuses      = {}
        self._total_items   = 0
        self._columns       = MIN_COLUMNS
        self._debounce_id   = None
        self._dash_visible  = False
        self._dash_panel    = None

        # Icono personalizado de la app
        try:
            _icon_pil   = _make_app_icon()
            _icon_photo = ImageTk.PhotoImage(_icon_pil)
            self.iconphoto(True, _icon_photo)
            self._icon_ref = _icon_photo   # anti-GC
        except Exception as e:
            log.warning(f"Icon: {e}")

        self._build_ui()
        self._bind_shortcuts()
        self._enable_drag_drop()

        if not CFG.get("omdb_api_key") and not CFG.get("tmdb_api_key"):
            self.after(200, lambda: SetupWizard(self, self.refresh))
        else:
            self.refresh()

        self.protocol("WM_DELETE_WINDOW", self._on_close)
        log.info(f"App v{VERSION} iniciada. BD: {DB_PATH}")

    # ── SHORTCUTS ─────────────────────────────────────────

    def _bind_shortcuts(self):
        self.bind("<Control-n>",  lambda e: self.add_item())
        self.bind("<Control-N>",  lambda e: self.add_item())
        self.bind("<Control-f>",  lambda e: self._focus_search())
        self.bind("<Control-F>",  lambda e: self._focus_search())
        self.bind("<F5>",         lambda e: self.refresh())
        self.bind("<Control-d>",  lambda e: self.dashboard())
        self.bind("<Control-D>",  lambda e: self.dashboard())
        self.bind("<Control-s>",  lambda e: self._open_smart_search())
        self.bind("<Control-S>",  lambda e: self._open_smart_search())
        self.bind("<Escape>",     lambda e: self._clear_search())

    def _focus_search(self):
        try:
            self._search_entry.focus()
            self._search_entry.select_range(0, "end")
        except Exception:
            pass

    def _clear_search(self):
        """Escape: limpia la búsqueda si hay texto, sin cerrar la app."""
        if self.search_var.get():
            self.search_var.set("")

    # ── DRAG & DROP ────────────────────────────────────────

    def _enable_drag_drop(self):
        """Acepta .txt/.csv arrastrados sobre la ventana."""
        try:
            self.drop_target_register = None  # tkinterdnd2 no siempre disponible
            # Intento sin dependencia externa: bind <Drop> si existe
            self.tk.call("package", "require", "tkdnd")
            self.drop_target_register("DND_Files")
            self.dnd_bind("<<Drop>>", self._on_drop)
        except Exception:
            pass  # No soportado en esta instalación, ignorar silenciosamente

    def _on_drop(self, event):
        path = event.data.strip("{}")
        if path.lower().endswith((".txt", ".csv")):
            dlg = BatchImportDialog(self, self.db, self.refresh, self)
            try:
                content = Path(path).read_text(encoding="utf-8", errors="ignore")
                dlg.text.insert("1.0", content)
            except Exception:
                pass

    # ── UI BUILD ──────────────────────────────────────────

    def _build_ui(self):
        self._build_topbar()
        self._build_toolbar()
        self._build_grid_area()
        self._build_statusbar()

    def _build_topbar(self):
        bar = tk.Frame(self, bg=C["topbar"], height=56)
        bar.pack(fill="x")
        bar.pack_propagate(False)

        # Línea de acento inferior
        tk.Frame(bar, bg=C["accent"], height=2).place(relx=0, rely=1.0,
                                                       relwidth=1.0, anchor="sw")

        # Logo
        logo_f = tk.Frame(bar, bg=C["topbar"])
        logo_f.pack(side="left", padx=16)
        tk.Label(logo_f, text="🎬", bg=C["topbar"], fg=C["accent"],
                 font=(FONT_FAMILY, 18)).pack(side="left")
        tk.Label(logo_f, text=" VIDEOCLUB", bg=C["topbar"], fg=C["text"],
                 font=(FONT_FAMILY, 18, "bold")).pack(side="left")
        tk.Label(logo_f, text=f"  v{VERSION}", bg=C["topbar"], fg=C["muted"],
                 font=(FONT_FAMILY, 9)).pack(side="left", pady=(4, 0))

        # Zona derecha
        right = tk.Frame(bar, bg=C["topbar"])
        right.pack(side="right", padx=16)

        # Pill de usuario
        pill = tk.Frame(right, bg=C["border"])
        pill.pack(side="left", padx=(0, 8))
        tk.Label(pill, text="👤", bg=C["border"], fg=C["muted"],
                 font=(FONT_FAMILY, 11), padx=6).pack(side="left")
        self.user_lbl = tk.Label(pill, text=self.active_user,
                                  bg=C["border"], fg=C["text"],
                                  font=(FONT_FAMILY, 10, "bold"), padx=6)
        self.user_lbl.pack(side="left")
        tk.Button(pill, text="▾", bg=C["border"], fg=C["muted"],
                  font=(FONT_FAMILY, 10), relief="flat", padx=6,
                  command=self.set_user, cursor="hand2").pack(side="left")

        tk.Button(right, text="⚙", bg=C["surface"], fg=C["muted"],
                  font=(FONT_FAMILY, 13), relief="flat", padx=8, pady=4,
                  command=lambda: SetupWizard(self, self.refresh),
                  cursor="hand2").pack(side="left")

    def _build_toolbar(self):
        self.toolbar = tk.Frame(self, bg=C["bg"], pady=8)
        self.toolbar.pack(fill="x", padx=14)
        self._fill_toolbar()

    def _fill_toolbar(self):
        for w in self.toolbar.winfo_children():
            w.destroy()

        # ── Fila 1: acciones + filtro tipo ───────────────────────────────────
        row1 = tk.Frame(self.toolbar, bg=C["bg"])
        row1.pack(fill="x")

        tk.Button(row1, text="＋ Añadir", bg=C["accent"], fg="white",
                  font=(FONT_FAMILY, 11, "bold"), relief="flat",
                  padx=14, pady=5, cursor="hand2",
                  command=self.add_item).pack(side="left")
        Tooltip(row1.winfo_children()[-1], "Ctrl+N — Añadir película o serie")

        tk.Button(row1, text="🔍 Buscar", bg=C["search_dark"], fg=C["text"],
                  font=(FONT_FAMILY, 10), relief="flat",
                  padx=10, pady=5, cursor="hand2",
                  command=self._open_smart_search).pack(side="left", padx=4)
        Tooltip(row1.winfo_children()[-1], "Búsqueda inteligente: OMDb · TMDb · Web · YouTube")

        tk.Button(row1, text="🎲 Recomienda", bg=C["recommend"], fg="white",
                  font=(FONT_FAMILY, 10), relief="flat",
                  padx=10, pady=5, cursor="hand2",
                  command=self.recommend).pack(side="left", padx=(0, 4))

        dash_active = getattr(self, '_dash_visible', False)
        tk.Button(row1, text="📊 Dashboard" if not dash_active else "📊 ✕ Cerrar",
                  bg=C["accent"] if dash_active else C["surface"],
                  fg="white", font=(FONT_FAMILY, 10), relief="flat",
                  padx=10, pady=5, cursor="hand2",
                  command=self.dashboard).pack(side="left")
        Tooltip(row1.winfo_children()[-1], "Ctrl+D — Estadísticas y exportar")

        # ── Botón "⋯ Más" con menú desplegable ───────────────────────────────
        more_btn = tk.Button(row1, text="⋯ Más", bg=C["surface"], fg=C["muted"],
                             font=(FONT_FAMILY, 10), relief="flat",
                             padx=10, pady=5, cursor="hand2")
        more_btn.pack(side="left", padx=(4, 0))
        more_btn.config(command=lambda b=more_btn: self._show_more_menu(b))
        Tooltip(more_btn, "Exportar · Colección · Herramientas")

        tk.Frame(row1, bg=C["bg"]).pack(side="left", expand=True, fill="x")

        # Contar ítems por tipo para las etiquetas
        all_db = self._all_items if self._all_items else []
        n_all    = len(all_db)
        n_movie  = sum(1 for i in all_db if i["type"] == "movie")
        n_series = sum(1 for i in all_db if i["type"] == "series")
        type_labels = [
            (f"Todo ({n_all})",          "all"),
            (f"🎬 Películas ({n_movie})", "movie"),
            (f"📺 Series ({n_series})",  "series"),
        ]
        current = self.filter_type.get()
        for label, val in type_labels:
            active = current == val
            tk.Button(row1, text=label,
                      bg=C["accent"] if active else C["surface"],
                      fg="white", font=(FONT_FAMILY, 10), relief="flat",
                      padx=9, pady=5, cursor="hand2",
                      command=lambda v=val: self._set_filter(v)
                      ).pack(side="left", padx=2)

        # ── Fila 2: búsqueda + ordenación ────────────────────────────────────
        row2 = tk.Frame(self.toolbar, bg=C["bg"])
        row2.pack(fill="x", pady=(5, 0))

        sf = tk.Frame(row2, bg=C["surface"])
        sf.pack(side="left")
        tk.Label(sf, text="🔍", bg=C["surface"], fg=C["muted"]).pack(side="left", padx=4)
        self._search_entry = tk.Entry(sf, textvariable=self.search_var,
                                       bg=C["surface"], fg=C["text"],
                                       insertbackground=C["text"],
                                       relief="flat", font=(FONT_FAMILY, 11), width=22)
        self._search_entry.pack(side="left", ipady=5)
        Tooltip(self._search_entry, "Ctrl+F — Buscar en biblioteca local (título, género, año, sinopsis)")
        self.search_var.trace_add("write", lambda *_: self._debounce_search())

        tk.Label(row2, text="Ordenar:", bg=C["bg"], fg=C["muted"],
                 font=(FONT_FAMILY, 9)).pack(side="left", padx=(12, 4))
        for label, val in [("A-Z", "title"), ("⭐ Rating", "rating"),
                            ("📅 Año", "year"), ("🕐 Añadido", "added")]:
            active = self.sort_order.get() == val
            tk.Button(row2, text=label,
                      bg=C["border"] if active else C["surface"],
                      fg=C["accent"] if active else C["text"],
                      font=(FONT_FAMILY, 9), relief="flat",
                      padx=7, pady=4, cursor="hand2",
                      command=lambda v=val: self._set_sort(v)
                      ).pack(side="left", padx=1)

        gf = self.genre_filter.get()
