        tk.Entry(mrow, textvariable=self._manual_title,
                 bg=C["surface"], fg=C["text"], insertbackground=C["text"],
                 font=(FONT_FAMILY, 11), relief="flat"
                 ).pack(side="left", fill="x", expand=True, ipady=6)
        self._manual_type = tk.StringVar(value="movie")
        om = tk.OptionMenu(mrow, self._manual_type, "movie", "series")
        om.config(bg=C["surface"], fg=C["text"], font=(FONT_FAMILY, 10),
                  relief="flat", highlightthickness=0, activebackground=C["hover"],
                  width=8)
        om["menu"].config(bg=C["surface"], fg=C["text"])
        om.pack(side="left", padx=(6, 0))
        tk.Button(mrow, text="➕ Añadir", bg=C["seen"], fg="white",
                  font=(FONT_FAMILY, 10, "bold"), relief="flat",
                  padx=12, pady=5, cursor="hand2",
                  command=self._add_manual).pack(side="left", padx=(6, 0))

        # ── Links externos ─────────────────────────────────────
        tk.Frame(self._result_frame, bg=C["border"], height=1).pack(fill="x", pady=(12, 6))
        tk.Label(self._result_frame, text="Buscar en plataformas externas:",
                 bg=C["bg"], fg=C["muted"], font=(FONT_FAMILY, 9)).pack(anchor="w")
        lf = tk.Frame(self._result_frame, bg=C["bg"])
        lf.pack(anchor="w", pady=(4, 12))
        for label, key, color in [
            ("▶ YouTube",      "youtube",      C["youtube"]),
            ("📸 Instagram",   "instagram",    C["ig"]),
            ("♪ TikTok",       "tiktok",       "#555"),
            ("🔍 Google",      "google",       C["web"]),
            ("🎬 Letterboxd",  "letterboxd",   "#ff8000"),
            ("🎭 FilmAffinity","filmaffinity", "#a00000"),
        ]:
            tk.Button(lf, text=label, bg=color, fg="white",
                      font=(FONT_FAMILY, 9), relief="flat", padx=8, pady=4, cursor="hand2",
                      command=lambda u=links.get(key, ""): webbrowser.open(u)
                      ).pack(side="left", padx=3)

        self._canvas.yview_moveto(0)

    def _build_result_card(self, data: dict):
        """Tarjeta con badge de fuente, badge de tipo y botón Añadir."""
        title   = data.get("Title", "")
        is_dup  = self.db.item_exists(title, self.app_root.active_user_id)
        itype   = detect_type(data)

        card = tk.Frame(self._result_frame, bg=C["surface"], padx=14, pady=10)
        card.pack(fill="x", pady=3)

        # Fila cabecera: [OMDB] [📺 SERIE] Título (año)   [➕ Añadir]
        hdr = tk.Frame(card, bg=C["surface"])
        hdr.pack(fill="x")

        src = data.get("_source", "")
        src_colors = {"omdb": ("#f5c518", "black"), "tmdb": ("#01b4e4", "white")}
        sbg, sfg = src_colors.get(src, (C["border"], C["text"]))
