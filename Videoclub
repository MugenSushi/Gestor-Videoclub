    return CACHE_DIR / f"{safe}.jpg"


def make_placeholder_image(title: str) -> Image.Image:
    """Genera imagen PIL (no PhotoImage) — seguro en cualquier thread."""
    img  = Image.new("RGB", (POSTER_W, POSTER_H), "#1a1a24")
    draw = ImageDraw.Draw(img)
    for y in range(POSTER_H):
        v = int(20 + 18 * (y / POSTER_H))
        draw.line([(0, y), (POSTER_W, y)], fill=(v, v, v + 12))
    cx, cy = POSTER_W // 2, POSTER_H // 2
    draw.rectangle([cx-24, cy-34, cx+24, cy+10], outline="#e50914", width=2)
    draw.polygon([(cx-12, cy+10), (cx+12, cy+10), (cx, cy+32)], outline="#e50914")
    # Texto centrado del título
    words = title[:18].upper()
    try:
        draw.text((cx, POSTER_H - 28), words, fill="#555566", anchor="mm")
    except Exception:
        pass
    return img


def get_poster_async(title: str, poster_url: str, callback, app_root: tk.Tk):
    """
    BUG1 FIX: 
    - Muestra placeholder PIL inmediato (sin esperar red).
    - Luego carga imagen real en thread del pool.
    - ImageTk.PhotoImage SIEMPRE se crea en hilo principal via after().
    """
    # Placeholder inmediato (en hilo principal, antes de lanzar thread)
    if title not in _poster_mem:
        ph_img  = make_placeholder_image(title)
        ph_img  = ph_img.resize((POSTER_W, POSTER_H), Image.Resampling.LANCZOS)
        ph_photo = ImageTk.PhotoImage(ph_img)
        _poster_mem[title] = ph_photo
        try:
            callback(ph_photo)
        except Exception:
            pass

    # Si ya teníamos el real en caché, entregar inmediatamente
    cached = _poster_mem.get(title)
    if cached and getattr(cached, '_is_real', False):
        callback(cached)
        return

    def _worker():
        if _stop_event.is_set():
            return
        img = None
        try:
            path = safe_filename(title)
            if path.exists():
                img = Image.open(path).convert("RGB")
            elif poster_url and poster_url not in ("N/A", ""):
                resp = requests.get(poster_url, timeout=12, stream=True)
                img  = Image.open(resp.raw).convert("RGB")
                with _poster_lock:          # evita escritura simultánea del mismo archivo
                    if not path.exists():   # re-check dentro del lock
                        img.save(path)
        except Exception as e:
            log.warning(f"Poster [{title}]: {e}")

        if img is None:
            return   # ya tenemos placeholder, no hace falta reemplazar

        img = img.resize((POSTER_W, POSTER_H), Image.Resampling.LANCZOS)

        def _finalize():
            if _stop_event.is_set():
                return
            photo = ImageTk.PhotoImage(img)
            photo._is_real = True           # marca que es imagen real
            _poster_mem[title] = photo
            try:
                callback(photo)
            except Exception:
                pass

        if not _stop_event.is_set():
            try:
                app_root.after(0, _finalize)
            except Exception:
                pass

    _poster_pool.submit(_worker)


