        self.bind("<Escape>", lambda e: self.destroy())

    def _center(self):
        self.update_idletasks()
        x = (self.winfo_screenwidth()  - self.winfo_width())  // 2
        y = (self.winfo_screenheight() - self.winfo_height()) // 2
        self.geometry(f"+{x}+{y}")

    def _build(self):
        f = tk.Frame(self, bg=C["bg"], padx=24, pady=20)
        f.pack(fill="both", expand=True)

        tk.Label(f, text="👤 Perfiles", bg=C["bg"], fg=C["text"],
                 font=(FONT_FAMILY, 15, "bold")).pack(pady=(0, 14))

        self._list_frame = tk.Frame(f, bg=C["bg"])
        self._list_frame.pack(fill="x", pady=(0, 8))
        self._fill_users()

        tk.Frame(f, bg=C["border"], height=1).pack(fill="x", pady=(4, 12))

        # ── Nuevo perfil ─────────────────────────────────────
        tk.Label(f, text="Nuevo perfil:", bg=C["bg"], fg=C["muted"],
                 font=(FONT_FAMILY, 9)).pack(anchor="w", pady=(0, 4))
        nr = tk.Frame(f, bg=C["bg"])
        nr.pack(fill="x")
        self._ne = tk.Entry(nr, bg=C["surface"], fg=C["text"],
                            insertbackground=C["text"], relief="flat",
                            font=(FONT_FAMILY, 11))
        self._ne.pack(side="left", fill="x", expand=True, ipady=6)
        self._ne.bind("<Return>", lambda _: self._add())
        tk.Button(nr, text="Crear", bg=C["surface"], fg=C["text"],
                  font=(FONT_FAMILY, 10), relief="flat",
                  padx=12, pady=5, cursor="hand2",
                  command=self._add).pack(side="left", padx=(6, 0))

    def _fill_users(self):
        for w in self._list_frame.winfo_children():
            w.destroy()
        for u in self.db.get_users():
            name      = u["name"]
            is_active = name == self._current
            row = tk.Frame(self._list_frame, bg=C["surface"])
            row.pack(fill="x", pady=2)

            # Botón nombre — selecciona el perfil
            tk.Button(row,
                      text=("▶  " if is_active else "    ") + name,
                      bg=C["accent"] if is_active else C["surface"],
                      fg="white",
                      font=(FONT_FAMILY, 11, "bold" if is_active else "normal"),
                      relief="flat", padx=10, pady=8,
                      cursor="hand2", anchor="w", width=18,
                      command=lambda n=name: self._select(n)
                      ).pack(side="left", fill="x", expand=True)

            # Renombrar
            tk.Button(row, text="✏", bg=C["surface"], fg=C["muted"],
                      font=(FONT_FAMILY, 11), relief="flat",
                      padx=8, pady=6, cursor="hand2",
                      command=lambda n=name: self._rename(n)
                      ).pack(side="left", padx=1)

            # Eliminar (bloqueado para Default)
            can_del = name != "Default"
            tk.Button(row, text="🗑",
                      bg="#4a0e0e" if can_del else C["border"],
                      fg="white"   if can_del else C["muted"],
                      font=(FONT_FAMILY, 11), relief="flat",
                      padx=8, pady=6,
                      cursor="hand2" if can_del else "arrow",
                      state="normal" if can_del else "disabled",
                      command=lambda n=name: self._delete(n)
                      ).pack(side="left", padx=(1, 4))

    # ── Acciones ─────────────────────────────────────────────

    def _select(self, name: str):
        self.destroy()          # libera grab_set ANTES de refrescar
        self.on_select(name)

    def _add(self):
        name = self._ne.get().strip()
        if not name:
            return
        if self.db.add_user(name):
            self.destroy()
            self.on_select(name)
        else:
            # Nombre duplicado — parpadeo rojo en el campo
            self._ne.config(fg=C["accent"])
            self._ne.after(800, lambda: self._ne.config(fg=C["text"]))

    def _rename(self, old_name: str):
        dlg = tk.Toplevel(self)
        dlg.title("Renombrar perfil")
        dlg.configure(bg=C["bg"])
        dlg.resizable(False, False)
        dlg.grab_set()

        f = tk.Frame(dlg, bg=C["bg"], padx=20, pady=16)
        f.pack()
        tk.Label(f, text=f"Nuevo nombre para «{old_name}»:",
                 bg=C["bg"], fg=C["text"],
                 font=(FONT_FAMILY, 10)).pack(anchor="w", pady=(0, 6))

        var = tk.StringVar(value=old_name)
        entry = tk.Entry(f, textvariable=var, bg=C["surface"], fg=C["text"],
                         insertbackground=C["text"], relief="flat",
                         font=(FONT_FAMILY, 11), width=22)
        entry.pack(fill="x", ipady=6)
        entry.select_range(0, "end")
        entry.focus()

        def _do():
            new_name = var.get().strip()
            if not new_name or new_name == old_name:
                dlg.destroy()
                return
            if self.db.rename_user(old_name, new_name):
                dlg.destroy()
                if old_name == self._current:
                    # Perfil activo renombrado → actualizar todo y cerrar
                    self._current = new_name
                    self.destroy()
                    self.on_select(new_name)
                else:
                    self._fill_users()
            else:
                entry.config(fg=C["accent"])
                entry.after(800, lambda: entry.config(fg=C["text"]))

        entry.bind("<Return>", lambda e: _do())
        bf = tk.Frame(f, bg=C["bg"])
        bf.pack(pady=(10, 0))
        tk.Button(bf, text="Guardar", bg=C["accent"], fg="white",
                  font=(FONT_FAMILY, 10, "bold"), relief="flat",
                  padx=12, pady=4, cursor="hand2",
                  command=_do).pack(side="left", padx=(0, 4))
        tk.Button(bf, text="Cancelar", bg=C["border"], fg=C["muted"],
                  font=(FONT_FAMILY, 10), relief="flat",
                  padx=8, pady=4, cursor="hand2",
                  command=dlg.destroy).pack(side="left")

        dlg.update_idletasks()
        x = (dlg.winfo_screenwidth()  - dlg.winfo_width())  // 2
        y = (dlg.winfo_screenheight() - dlg.winfo_height()) // 2
        dlg.geometry(f"+{x}+{y}")

    def _delete(self, name: str):
        if name == "Default":
            return
        if not messagebox.askyesno(
            "Eliminar perfil",
            f"¿Eliminar el perfil «{name}»?\n\nSe borrarán su historial y puntuaciones.",
            parent=self
        ):
            return
        if self.db.delete_user(name):
            if self._current == name:
                # El perfil activo fue borrado → volver a Default
                self.destroy()
                self.on_select("Default")
            else:
                self._fill_users()


