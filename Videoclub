def fetch_omdb_multi(title: str, type_hint: str = "") -> list:
    """OMDb búsqueda multi-resultado (?s=) — devuelve lista de coincidencias.
    type_hint: "" = todos, "movie" = solo películas, "series" = solo series."""
    key = CFG.get("omdb_api_key", "")
    if not key:
        return []
    try:
        type_param = f"&type={type_hint}" if type_hint in ("movie", "series") else ""
        url = f"http://www.omdbapi.com/?s={quote(title)}&apikey={key}{type_param}"
        data = requests.get(url, timeout=8).json()
        if data.get("Response") == "True":
            results = []
            for item in data.get("Search", [])[:10]:
                poster = item.get("Poster", "")
                results.append({
                    "Title":      item.get("Title", ""),
                    "Type":       "series" if item.get("Type") == "series" else "movie",
                    "Year":       item.get("Year", ""),
                    "Genre":      "",
                    "Plot":       "",
                    "imdbRating": "",
                    "Poster":     poster if poster != "N/A" else "",
                    "_source":    "omdb",
                    "_imdbID":    item.get("imdbID", ""),
                })
            return results
        log.warning(f"OMDb multi: {title} → {data.get('Error','')}")
    except Exception as e:
        log.error(f"fetch_omdb_multi: {e}")
    return []


