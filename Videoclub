class ContentCard(tk.Frame):
    """Tarjeta de contenido: poster fijo + título adaptable + rating + botones."""
    def __init__(self, parent, item: dict, user_id: int, db: Database,
                 on_refresh, statuses: dict, app_root: tk.Tk):
        super().__init__(parent, bg=C["card"], cursor="hand2")
        self.item       = item
        self.user_id    = user_id
        self.db         = db
        self.on_refresh = on_refresh
        self.status     = statuses.get(item["title"], STATUS_NONE)
        self.app_root   = app_root
        self._photo     = None
        self._build()
        self._load_poster()

    def _build(self):
        title  = self.item["title"]
        status = self.status

        # ── ZONA POSTER — height exacta, propagate desactivado ──
        poster_zone = tk.Frame(self, bg=C["card"], width=CARD_W, height=POSTER_H)
        poster_zone.pack_propagate(False)
        poster_zone.pack(side="top")

        # Placeholder PIL inmediato → nunca aparece negro
        ph_pil   = make_placeholder_image(title)
        self._photo = ImageTk.PhotoImage(ph_pil)   # referencia para GC
        self.poster_lbl = tk.Label(
            poster_zone, image=self._photo,
            bg=C["card"], borderwidth=0, highlightthickness=0,
            width=POSTER_W, height=POSTER_H
        )
        self.poster_lbl.pack()

        # Badges encima del poster (place, no pack)
        if status == STATUS_WATCHED:
            tk.Label(poster_zone, text="✓ VISTO", bg=C["seen"], fg="white",
                     font=(FONT_FAMILY, 7, "bold"), padx=3
                     ).place(x=2, y=2)
        elif status == STATUS_PENDING:
            tk.Label(poster_zone, text="⏳ PDTE", bg=C["pending"], fg="white",
                     font=(FONT_FAMILY, 7, "bold"), padx=3
                     ).place(x=2, y=2)

        tc = C["accent"] if self.item["type"] == "movie" else C["series_badge"]
        tk.Label(poster_zone,
                 text="🎬" if self.item["type"] == "movie" else "📺",
                 bg=tc, fg="white", font=(FONT_FAMILY, 8), padx=2
                 ).place(x=CARD_W - 24, y=2)

        self.poster_lbl.bind("<Button-1>", lambda e: self._show_detail())
        poster_zone.bind("<Button-1>",     lambda e: self._show_detail())

        # ── ZONA TÍTULO — altura libre, texto wraps ──────────
        title_lbl = tk.Label(
            self, text=title,
            bg=C["card"], fg=C["text"],
            font=(FONT_FAMILY, 9, "bold"),
            wraplength=CARD_W - 10, justify="center",
            anchor="center", pady=3
        )
        title_lbl.pack(side="top", fill="x")
        year = self.item.get("year", "")
        Tooltip(title_lbl, f"{title}  ({year})" if year else title)
        title_lbl.bind("<Button-1>", lambda e: self._show_detail())

        # ── ZONA RATING ───────────────────────────────────────
        rating = self.item.get("rating")
        if rating:
            tk.Label(self, text=f"★ {rating}",
                     bg=C["card"], fg=C["gold"],
                     font=(FONT_FAMILY, 8), pady=2).pack(side="top")

        # ── ZONA BOTONES ──────────────────────────────────────
        btn_zone = tk.Frame(self, bg=C["card"])
        btn_zone.pack(side="top", fill="x", padx=3, pady=(2, 4))

        tk.Button(
            btn_zone, text="Info", bg=C["accent"], fg="white",
            font=(FONT_FAMILY, 8, "bold"), relief="flat",
            cursor="hand2", command=self._show_detail
        ).pack(side="left", fill="both", expand=True, padx=(0, 1))

        lbl, col = self._next_status_ui()
        tk.Button(
            btn_zone, text=lbl, bg=col, fg="white",
            font=(FONT_FAMILY, 8), relief="flat",
            cursor="hand2", command=self._cycle_status
        ).pack(side="left", fill="both", expand=True, padx=(1, 0))

        # Hover
        for w in [self, poster_zone, title_lbl, btn_zone]:
            w.bind("<Enter>", lambda e: self.config(bg=C["hover"]))
            w.bind("<Leave>", lambda e: self.config(bg=C["card"]))

    def _next_status_ui(self):
        return {
            STATUS_NONE:    ("⏳ Luego",  C["pending"]),
            STATUS_PENDING: ("✓ Visto",   C["seen"]),
            STATUS_WATCHED: ("↩ Quitar",  C["border"]),
        }.get(self.status, ("⏳ Luego", C["pending"]))

    def _load_poster(self):
        def _cb(photo):
            # Guardar referencia en la instancia Y en el label para evitar GC
            self._photo = photo
            try:
                self.poster_lbl.config(image=photo)
                self.poster_lbl.image = photo   # referencia extra anti-GC
            except Exception:
                pass
        get_poster_async(self.item["title"],
                         self.item.get("poster_url", ""), _cb, self.app_root)

    def _show_detail(self):
        DetailWindow(self.winfo_toplevel(), self.item,
                     self.user_id, self.db, self.on_refresh, self.app_root)

    def _cycle_status(self):
        cycle = {STATUS_NONE: STATUS_PENDING,
                 STATUS_PENDING: STATUS_WATCHED,
                 STATUS_WATCHED: STATUS_NONE}
        new = cycle.get(self.status, STATUS_NONE)
        self.db.set_status(self.user_id, self.item["title"], new)
        self.on_refresh()


