                  font=(FONT_FAMILY, 10), relief="flat",
                  padx=12, pady=6, cursor="hand2",
                  command=self._skip).pack(side="left", padx=4)

    def _save(self):
        CFG["omdb_api_key"] = self._omdb.get().strip()
        CFG["tmdb_api_key"] = self._tmdb.get().strip()
        save_config(CFG)
        # Limpiar caché de funciones LRU tras cambio de key
        fetch_omdb.cache_clear()
        fetch_tmdb.cache_clear()
        log.info("Config guardada.")
        self.destroy()
        self.on_done()

    def _skip(self):
        self.destroy()
        self.on_done()


