    def rename_user(self, old_name: str, new_name: str) -> bool:
        try:
            self.conn.execute("UPDATE users SET name=? WHERE name=?", (new_name, old_name))
            self.conn.commit()
            return True
        except Exception as e:
            log.error(f"rename_user: {e}")
            return False

    def delete_user(self, name: str) -> bool:
        """Elimina el perfil, su historial y su biblioteca. No borra 'Default'."""
        if name == "Default":
            return False
        try:
            uid = self.get_user_id(name)
            if not uid:
                return False
            # Borrar en orden para respetar FK (foreign_keys = ON)
            self.conn.execute("DELETE FROM watched    WHERE user_id=?", (uid,))
            self.conn.execute("DELETE FROM user_items WHERE user_id=?", (uid,))
            self.conn.execute("DELETE FROM users      WHERE id=?",      (uid,))
            # Limpiar items huérfanos (sin ningún usuario que los tenga)
            self.conn.execute("""
                DELETE FROM items WHERE title NOT IN
                    (SELECT DISTINCT title FROM user_items)
            """)
            self.conn.commit()
            return True
        except Exception as e:
            log.error(f"delete_user: {e}")
            return False

    # ── Stats ──────────────────────────────────────────────

    def count_items(self, user_id: int = 0) -> int:
        if user_id:
            return self.conn.execute(
                "SELECT COUNT(*) FROM user_items WHERE user_id=?", (user_id,)
            ).fetchone()[0]
        return self.conn.execute("SELECT COUNT(*) FROM items").fetchone()[0]

    def count_by_status(self, user_id: int) -> dict:
        result = {STATUS_WATCHED: 0, STATUS_PENDING: 0}
        for r in self.conn.execute(
            "SELECT status, COUNT(*) as n FROM watched WHERE user_id=? GROUP BY status",
            (user_id,)
        ).fetchall():
            result[r["status"]] = r["n"]
        return result

    def get_stats(self) -> tuple:
        r = self.conn.execute(
            "SELECT SUM(type='movie'), SUM(type='series') FROM items"
        ).fetchone()
        return (r[0] or 0), (r[1] or 0)

    def get_dashboard_stats(self, user_id: int) -> dict:
        """Una sola llamada que agrega todos los datos para el panel Dashboard."""
        r = self.conn.execute("""
            SELECT COUNT(*) as total,
                   SUM(i.type='movie')  as movies,
                   SUM(i.type='series') as series,
                   AVG(CASE WHEN i.rating > 0 THEN i.rating END) as avg_rating
            FROM items i
            JOIN user_items ui ON ui.title=i.title AND ui.user_id=?
        """, (user_id,)).fetchone()
        by_status = self.count_by_status(user_id)
        avg_user  = self.get_avg_user_rating(user_id)
        return {
            "total":      r["total"]      or 0,
            "movies":     r["movies"]     or 0,
            "series":     r["series"]     or 0,
            "avg_rating": round(r["avg_rating"], 2) if r["avg_rating"] else 0.0,
            "watched":    by_status[STATUS_WATCHED],
            "pending":    by_status[STATUS_PENDING],
            "avg_user":   avg_user,
        }

    def get_top_genres(self, limit=5) -> list:
        counts = {}
        for row in self.conn.execute(
            "SELECT genres FROM items WHERE genres IS NOT NULL"
        ).fetchall():
            for g in row["genres"].split(","):
                g = g.strip()
                if g:
                    counts[g] = counts.get(g, 0) + 1
        return sorted(counts.items(), key=lambda x: -x[1])[:limit]

    def get_avg_rating(self) -> float:
        row = self.conn.execute(
            "SELECT AVG(rating) FROM items WHERE rating IS NOT NULL AND rating > 0"
        ).fetchone()
        return round(row[0], 2) if row[0] else 0.0

    def get_avg_user_rating(self, user_id: int) -> float:
        row = self.conn.execute(
            "SELECT AVG(user_rating) FROM watched WHERE user_id=? AND user_rating IS NOT NULL",
            (user_id,)
        ).fetchone()
        return round(row[0], 1) if row[0] else 0.0

    def get_monthly_added(self, months=6) -> list:
        rows = self.conn.execute("""
            SELECT strftime('%Y-%m', added_at) as month, COUNT(*) as n
            FROM items GROUP BY month ORDER BY month DESC LIMIT ?
        """, (months,)).fetchall()
        return [(r["month"], r["n"]) for r in reversed(rows)]

    def export_csv(self, path: str, user_id: int = 0):
        rows = [dict(i) for i in self.get_items(user_id=user_id)]
        with open(path, "w", newline="", encoding="utf-8") as f:
            w = csv.writer(f)
            w.writerow(["title","type","year","rating","genres",
                        "director","actors","studio","streaming","added_at"])
            for i in rows:
                w.writerow([i.get("title",""), i.get("type",""), i.get("year",""),
                            i.get("rating",""), i.get("genres",""),
                            i.get("director",""), i.get("actors",""),
                            i.get("studio",""), i.get("streaming",""),
                            i.get("added_at","")])

    def export_json(self, path: str, user_id: int = 0):
        rows = [dict(i) for i in self.get_items(user_id=user_id)]
        Path(path).write_text(
            json.dumps(rows, indent=2, ensure_ascii=False), encoding="utf-8"
        )

    def export_txt(self, path: str, user_id: int = 0, statuses: dict = None):
        """Lista legible: título · tipo · año · estado."""
        rows     = [dict(i) for i in self.get_items(user_id=user_id)]
        statuses = statuses or {}
        st_label = {STATUS_WATCHED: "✓ Visto", STATUS_PENDING: "⏳ Pendiente",
                    STATUS_NONE: "○ Sin ver"}
        lines = [f"VIDEOCLUB — {len(rows)} títulos\n{'='*50}\n"]
        for i in rows:
            st  = st_label.get(statuses.get(i.get("title",""), STATUS_NONE), "○ Sin ver")
            yr  = f" ({i['year']})" if i.get("year") else ""
            dir_= f"  Dir: {i['director']}" if i.get("director") else ""
            lines.append(f"{i.get('title','')}{yr}  [{i.get('type','').upper()}]  {st}{dir_}")
        Path(path).write_text("\n".join(lines), encoding="utf-8")

    def get_items_missing_meta(self, user_id: int) -> list:
        """Devuelve ítems del usuario que tienen director/actores vacíos."""
        return [dict(i) for i in self.conn.execute(
            """SELECT i.* FROM items i
               JOIN user_items ui ON ui.title=i.title AND ui.user_id=?
               WHERE (i.director IS NULL OR i.director='')
                  OR (i.actors   IS NULL OR i.actors='')""",
            (user_id,)
        ).fetchall()]

    def update_meta(self, title: str, director: str, actors: str,
                    studio: str, streaming: str, plot: str = "") -> None:
        """Actualiza los campos de metadata enriquecida de un ítem."""
        self.conn.execute(
            """UPDATE items SET
               director =COALESCE(NULLIF(?,''), director),
               actors   =COALESCE(NULLIF(?,''), actors),
               studio   =COALESCE(NULLIF(?,''), studio),
               streaming=COALESCE(NULLIF(?,''), streaming),
               plot     =COALESCE(NULLIF(?,''), plot)
               WHERE title=?""",
            (director, actors, studio, streaming, plot, title)
        )
        self.conn.commit()

    def close(self):
        self.conn.close()


