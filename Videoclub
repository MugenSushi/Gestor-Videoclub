            insertbackground=C["text"],
            font=(FONT_FAMILY, 10), wrap="word",
            relief="flat", height=3, width=46
        )
        saved_notes = self.db.get_notes(self.user_id, title)
        self._notes_txt.insert("1.0", saved_notes)
        self._notes_txt.pack(fill="x")
        tk.Button(right, text="💾 Guardar notas", bg=C["surface"], fg=C["muted"],
                  font=(FONT_FAMILY, 9), relief="flat", padx=8, pady=2,
                  cursor="hand2", command=self._save_notes).pack(anchor="e", pady=2)

    def _load_poster(self):
        def _cb(photo):
            self._photo = photo
            try:
                self.poster_lbl.config(image=photo, width=POSTER_W, height=POSTER_H)
                self.poster_lbl.image = photo   # anti-GC
            except Exception:
                pass
        get_poster_async(self.item["title"],
                         self.item.get("poster_url", ""), _cb, self.app_root)

    def _set_status(self, status: str):
        self.db.set_status(self.user_id, self.item["title"], status)
        self.on_refresh()
        self.destroy()

    def _save_rating(self, stars: int):
        self.db.set_user_rating(self.user_id, self.item["title"], stars)

    def _save_notes(self):
        notes = self._notes_txt.get("1.0", "end").strip()
        self.db.set_notes(self.user_id, self.item["title"], notes)

    def _filter_genre(self, genre: str):
        self.destroy()
        root = self.app_root
        if hasattr(root, 'set_genre_filter'):
            root.set_genre_filter(genre)

    def _open_seasons(self, tmdb_id: str, num_seasons: int):
        win = SeasonViewWindow(
            self,
            item=self.item,
            user_id=self.user_id,
            db=self.db,
            on_refresh=self.on_refresh,
            app_root=self.app_root,
        )
        win.bind(
            "<Destroy>",
            lambda e: self.grab_set() if self.winfo_exists() else None
        )

    def _delete(self):
        if messagebox.askyesno("Eliminar",
                               f"¿Eliminar '{self.item['title']}' de la biblioteca?",
                               parent=self):
            title = self.item["title"]
            self.db.delete_item(title, self.user_id)
            show_toast(self.app_root, f'"{title}" eliminado', kind="warn")
            self.on_refresh()
            self.destroy()


