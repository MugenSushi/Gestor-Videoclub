            else:
                self.conn.execute(
                    "INSERT INTO watched(user_id,title,status) VALUES(?,?,?)"
                    " ON CONFLICT(user_id,title) DO UPDATE SET"
                    " status=excluded.status, watched_at=datetime('now')",
                    (user_id, title, status)
                )
            self.conn.commit()
            return True
        except Exception as e:
            log.error(f"set_status: {e}")
            return False

