    def _load_items(self) -> list:
        query = self.search_var.get().strip()
        ftype = self.filter_type.get()
        order = self.sort_order.get()
        genre = self.genre_filter.get()
        sf    = self.status_filter.get()
        uid   = self.active_user_id

        if query:
            items = self.db.search_items(query, order, uid)
        elif genre:
            items = self.db.get_items_by_genre(genre, order, uid)
        else:
            items = self.db.get_items(order, uid)

        if ftype != "all":
            items = [i for i in items if i["type"] == ftype]

        if sf != "all":
            items = [i for i in items
                     if self._statuses.get(i["title"], STATUS_NONE) == sf]

        return items

    def refresh(self):
        for w in self.grid_frame.winfo_children():
            w.destroy()
        self._cards.clear()

        self._total_items = self.db.count_items(self.active_user_id)
        self._statuses    = self.db.get_all_statuses(self.active_user_id)
        self._all_items   = self._load_items()
        self._page        = 0
        # Columnas según ancho actual del canvas (si ya está renderizado)
        cw = self.canvas.winfo_width()
        if cw > 1:
            self._columns = max(MIN_COLUMNS, cw // (CARD_W + CARD_GRID_PAD * 2))
        self._fill_toolbar()
        self._update_statusbar_counters()
        self._render_page()

    def _render_page(self):
        start = self._page * PAGE_SIZE
        end   = start + PAGE_SIZE
        page_items = self._all_items[start:end]
        total = self._total_items

        if not self._all_items:
            ef = tk.Frame(self.grid_frame, bg=C["bg"])
            ef.pack(expand=True, pady=90)
            tk.Label(ef, text="▶", bg=C["bg"], fg=C["border"],
                     font=(FONT_FAMILY, 60)).pack()
            msg = "Tu biblioteca está vacía" if total == 0 else "Sin resultados"
            tk.Label(ef, text=msg, bg=C["bg"], fg=C["muted"],
                     font=(FONT_FAMILY, 15)).pack(pady=6)
            if total == 0:
                tk.Button(ef, text="＋ Añadir primera película",
                          bg=C["accent"], fg="white",
                          font=(FONT_FAMILY, 12, "bold"), relief="flat",
                          padx=18, pady=7, cursor="hand2",
                          command=self.add_item).pack()
            self._set_status(0, total)
            return

        base_idx = start
        for idx, item in enumerate(page_items):
            abs_idx = base_idx + idx
            card = ContentCard(
                self.grid_frame, dict(item),
                self.active_user_id, self.db,
                self.refresh, self._statuses, self
            )
            cols = self._columns
            card.grid(row=abs_idx // cols, column=abs_idx % cols,
                      padx=CARD_GRID_PAD, pady=CARD_GRID_PAD, sticky="nw")
            self._cards.append(card)

        has_more = end < len(self._all_items)
        if has_more:
            cols     = self._columns
            next_row = end // cols + 1
            mf = tk.Frame(self.grid_frame, bg=C["bg"])
            mf.grid(row=next_row, column=0, columnspan=cols, pady=16)
            remaining = len(self._all_items) - end
            tk.Button(
                mf,
                text=f"Cargar {min(remaining, PAGE_SIZE)} más  ({remaining} restantes)",
                bg=C["surface"], fg=C["text"],
                font=(FONT_FAMILY, 11), relief="flat",
                padx=20, pady=8, cursor="hand2",
                command=self._load_more
            ).pack()

        self._set_status(len(self._all_items), total)

    def _load_more(self):
        children = self.grid_frame.winfo_children()
        if children:
            last = children[-1]
            if isinstance(last, tk.Frame) and not isinstance(last, ContentCard):
                last.destroy()
        self._page += 1
        self._render_page()

    def _reset_page(self):
        self._page = 0
        self.refresh()

    def _set_status(self, shown: int, total: int):
        ft  = self.filter_type.get()
        ts  = f" ({ft}s)" if ft != "all" else ""
        gf  = self.genre_filter.get()
        gts = f" · Género: {gf}" if gf else ""
        rendered = min((self._page + 1) * PAGE_SIZE, shown)
        self.status_lbl.config(
            text=f"Mostrando {rendered}/{shown} de {total} títulos{ts}{gts}"
                 f"  ·  {self.active_user}"
        )

