@lru_cache(maxsize=400)
def fetch_tmdb(title: str) -> dict:
    """TMDb API — devuelve primer resultado (usado por smart_search/batch)."""
    key = CFG.get("tmdb_api_key", "")
    if not key:
        return {}
    try:
        search_url = (f"https://api.themoviedb.org/3/search/multi"
                      f"?api_key={key}&query={quote(title)}&language=es-ES")
        data = requests.get(search_url, timeout=8).json()
        results = data.get("results", [])
        if not results:
            return {}
        r = results[0]
        media = r.get("media_type", "movie")
        real_title = r.get("title") or r.get("name", title)
        poster_path = r.get("poster_path", "")
        poster_url  = f"https://image.tmdb.org/t/p/w500{poster_path}" if poster_path else ""
        return {
            "Title":      real_title,
            "Type":       "series" if media == "tv" else "movie",
            "Year":       str(r.get("release_date", r.get("first_air_date", ""))[:4]),
            "Genre":      "",
            "Plot":       r.get("overview", ""),
            "imdbRating": str(round(r.get("vote_average", 0), 1)),
            "Poster":     poster_url,
            "_source":    "tmdb",
        }
    except Exception as e:
        log.error(f"fetch_tmdb: {e}")
    return {}


def fetch_tmdb_multi(title: str, type_hint: str = "") -> list:
    """TMDb búsqueda multi-resultado — devuelve lista de coincidencias.
    type_hint: "" = todos, "movie" = solo películas, "series" = solo series."""
    key = CFG.get("tmdb_api_key", "")
    if not key:
        return []
    try:
        search_url = (f"https://api.themoviedb.org/3/search/multi"
                      f"?api_key={key}&query={quote(title)}&language=es-ES")
        data = requests.get(search_url, timeout=8).json()
        results = []
        for r in data.get("results", [])[:12]:
            media = r.get("media_type", "movie")
            if media not in ("movie", "tv"):
                continue
            item_type = "series" if media == "tv" else "movie"
            if type_hint == "movie" and item_type != "movie":
                continue
            if type_hint == "series" and item_type != "series":
                continue
            real_title  = r.get("title") or r.get("name", title)
            poster_path = r.get("poster_path", "")
            poster_url  = f"https://image.tmdb.org/t/p/w500{poster_path}" if poster_path else ""
            year_raw    = r.get("release_date") or r.get("first_air_date") or ""
            results.append({
                "Title":      real_title,
                "Type":       item_type,
                "Year":       year_raw[:4],
                "Genre":      "",
                "Plot":       r.get("overview", ""),
                "imdbRating": str(round(r.get("vote_average", 0), 1)),
                "Poster":     poster_url,
                "_source":    "tmdb",
                "_tmdb_id":   str(r.get("id", "")),
            })
        return results
    except Exception as e:
        log.error(f"fetch_tmdb_multi: {e}")
    return []


@lru_cache(maxsize=200)
def fetch_tmdb_detail(tmdb_id: str, media_type: str = "movie") -> dict:
    """TMDb detalles completos en una sola llamada: créditos + productora + streaming.
    Devuelve claves: Director, Actors, Studio, Streaming."""
    key = CFG.get("tmdb_api_key", "")
    if not key or not tmdb_id:
        return {}
    try:
        base = "movie" if media_type == "movie" else "tv"
        url  = (f"https://api.themoviedb.org/3/{base}/{tmdb_id}"
                f"?api_key={key}&language=es-ES"
                f"&append_to_response=credits,watch%2Fproviders")
        d = requests.get(url, timeout=10).json()

        # Director / creador
        crew = d.get("credits", {}).get("crew", [])
        if media_type == "movie":
            directors = [c["name"] for c in crew if c.get("job") == "Director"]
        else:
            directors = [c["name"] for c in crew
                         if c.get("job") in ("Executive Producer", "Creator")]
        director = ", ".join(directors[:2])

        # Actores (top 5)
        cast   = d.get("credits", {}).get("cast", [])[:5]
        actors = ", ".join(c["name"] for c in cast)

        # Estudio / red (cadena o productora)
        networks   = d.get("networks", [])
        companies  = d.get("production_companies", [])
        studio_src = networks[:2] or companies[:2]
        studio     = ", ".join(s["name"] for s in studio_src)

        # Streaming España (suscripción plana)
        wp        = d.get("watch/providers", {}).get("results", {}).get("ES", {})
        streaming = ", ".join(p["provider_name"] for p in wp.get("flatrate", [])[:4])

        result = {"Director": director, "Actors": actors,
                  "Studio": studio, "Streaming": streaming}
        if media_type != "movie":
            result["_num_seasons"] = d.get("number_of_seasons", 0)
            result["_seasons"]     = d.get("seasons", [])
        return result
    except Exception as e:
        log.error(f"fetch_tmdb_detail: {e}")
    return {}


@lru_cache(maxsize=50)
def _fetch_tmdb_season_cached(tmdb_id: str, season_number: int) -> dict:
    """Internal cached fetcher — only successful responses are cached.
    Use fetch_tmdb_season_episodes() as the public API."""
    key = CFG.get("tmdb_api_key", "")
    if not key or not tmdb_id:
        return {}
    try:
        url = (f"https://api.themoviedb.org/3/tv/{tmdb_id}"
               f"/season/{season_number}"
               f"?api_key={key}&language=es-ES")
        resp = requests.get(url, timeout=10)
        if resp.status_code == 200:
            return resp.json()
        elif resp.status_code == 404:
            log.warning(
                f"fetch_tmdb_season_episodes: 404 tmdb_id={tmdb_id} "
                f"season={season_number} — no data in TMDb yet"
            )
            return {"_404": True}   # sentinel — permanent, non-retryable, safe to cache
        elif resp.status_code == 429:
            log.warning(
                f"fetch_tmdb_season_episodes: 429 rate limit "
                f"tmdb_id={tmdb_id} season={season_number}"
            )
            import time; time.sleep(1)
            resp2 = requests.get(url, timeout=10)
            if resp2.status_code == 200:
                return resp2.json()
            log.error(
                f"fetch_tmdb_season_episodes: retry after 429 also failed "
                f"({resp2.status_code})"
            )
            return {}   # transient — NOT cached (public wrapper clears cache)
        else:
            log.error(
                f"fetch_tmdb_season_episodes: HTTP {resp.status_code} "
                f"tmdb_id={tmdb_id} season={season_number}"
            )
            return {}
    except Exception as e:
        log.error(f"fetch_tmdb_season_episodes: network error: {e}")
    return {}


def fetch_tmdb_season_episodes(tmdb_id: str, season_number: int) -> dict:
    """Returns TMDb season object with 'episodes' list.
    Cached per session for successful responses and permanent 404s.
    Transient network/5xx errors are NOT cached — next call retries.
    Returns {} on any error; caller checks data.get('episodes', [])."""
    result = _fetch_tmdb_season_cached(tmdb_id, season_number)
    if not result:
        # Transient error — clear cache so next call retries
        _fetch_tmdb_season_cached.cache_clear()
        return {}
    if result.get("_404"):
        return {}   # permanent 404 — already cached, return empty to caller
    return result


def fetch_duckduckgo(title: str) -> dict:
    """
    Búsqueda web general vía DuckDuckGo Instant Answer API.
    No requiere API key. Devuelve extracto + URL.
    """
    try:
        url = f"https://api.duckduckgo.com/?q={quote_plus(title+' película serie')}&format=json&no_html=1"
        data = requests.get(url, timeout=6).json()
        abstract = data.get("AbstractText", "")
        source   = data.get("AbstractURL", "")
        if abstract:
            return {"abstract": abstract, "url": source, "_source": "duckduckgo"}
    except Exception as e:
        log.error(f"fetch_duckduckgo: {e}")
    return {}


def _extract_extra(data: dict) -> dict:
    """Extrae Director, Actors, Studio, Streaming de un dict de datos API."""
    def _clean(v): return (v or "").strip() if v not in (None, "N/A") else ""
    return {
        "director":  _clean(data.get("Director")),
        "actors":    _clean(data.get("Actors")),
        "studio":    _clean(data.get("Studio") or data.get("Production")),
        "streaming": _clean(data.get("Streaming")),
    }


def smart_search(title: str) -> dict:
    """
    Búsqueda inteligente multi-fuente con fallback automático.
    Funciona SIN API keys gracias a DuckDuckGo.
    
    Orden:
      1. OMDb API  (mejor calidad, necesita key)
      2. TMDb API  (alternativa, necesita key)
      3. DuckDuckGo (sin key, datos básicos)
      4. Fallback manual: crea entrada básica con el título tal cual
    """
    # 1. OMDb
    if CFG.get("omdb_api_key"):
        result = fetch_omdb(title)
        if result:
            result["_source"] = "omdb"
            return result

    # 2. TMDb
    if CFG.get("tmdb_api_key"):
        result = fetch_tmdb(title)
        if result:
            return result

    # 3. DuckDuckGo — sin key, siempre disponible
    result = fetch_duckduckgo(title)
    if result and result.get("abstract"):
        # Construir estructura compatible con el resto del sistema
        return {
            "Title":      title,           # usamos el título original buscado
            "Type":       "movie",         # desconocido, asumir movie
            "Year":       "",
            "Genre":      "",
            "Plot":       result.get("abstract", ""),
            "imdbRating": "",
            "Poster":     "",
            "_source":    "duckduckgo",
        }

    # 4. Fallback manual — añadir sin metadatos para no perder el título
    log.info(f"smart_search fallback manual para: {title}")
    return {
        "Title":      title,
        "Type":       "movie",
        "Year":       "",
        "Genre":      "",
        "Plot":       "",
        "imdbRating": "",
        "Poster":     "",
        "_source":    "manual",
    }


def detect_type(data: dict) -> str:
    return "series" if "series" in data.get("Type", "").lower() else "movie"


def show_toast(root: tk.Tk, message: str, kind: str = "success", duration_ms: int = 2500):
    """Notificación pequeña y no-modal en la esquina inferior-derecha."""
    color = {"success": C["seen"], "error": C["accent"], "warn": C["pending"]}.get(kind, C["seen"])
    try:
        toast = tk.Toplevel(root)
        toast.overrideredirect(True)
        toast.attributes("-topmost", True)
        toast.configure(bg=color)
        tk.Label(toast, text=message, bg=color, fg="white",
                 font=(FONT_FAMILY, 10), padx=16, pady=10).pack()
        toast.update_idletasks()
        w = toast.winfo_reqwidth()
        h = toast.winfo_reqheight()
        sw = root.winfo_screenwidth()
        sh = root.winfo_screenheight()
        toast.geometry(f"+{sw - w - 24}+{sh - h - 80}")
        root.after(duration_ms, lambda: toast.destroy() if toast.winfo_exists() else None)
    except Exception:
        pass


def _make_app_icon() -> Image.Image:
    """Genera el icono de la app: clapperboard rojo sobre fondo oscuro."""
    size = 64
    img  = Image.new("RGBA", (size, size), (0, 0, 0, 0))
    d    = ImageDraw.Draw(img)
    # Fondo redondeado oscuro
    d.rounded_rectangle([0, 0, size-1, size-1], radius=12, fill="#0d0d14")
    # Cuerpo del clapperboard (rectángulo blanco)
    d.rounded_rectangle([8, 22, 56, 56], radius=4, fill="#e8e8f0")
    # Parte superior del clapper (rojo)
    d.rounded_rectangle([8, 10, 56, 26], radius=4, fill="#e50914")
    # Líneas diagonales del clapper (blanco sobre rojo)
    for i in range(5):
        x = 10 + i * 10
        d.line([(x, 10), (x + 6, 26)], fill="white", width=3)
    # Líneas de guión en el cuerpo (gris oscuro)
    for iy, tw in [(32, 34), (40, 26), (48, 20)]:
        d.rounded_rectangle([14, iy, 14 + tw, iy + 4], radius=2, fill="#aaaacc")
    return img


