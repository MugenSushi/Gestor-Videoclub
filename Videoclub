class SmartSearchDialog(tk.Toplevel):
    """
    Búsqueda inteligente v2.0
    - Multi-resultado: muestra TODAS las coincidencias (no solo la primera)
    - Filtro Todos / Película / Serie antes de buscar
    - Botón Añadir en cada resultado individual
    - Añadir manual: si lo encontraste en Letterboxd/FilmAffinity, rellena
      título + tipo y se auto-busca la metadata disponible
    """
    def __init__(self, parent, db: Database, on_success, app_root: tk.Tk, initial_title=""):
        super().__init__(parent)
        self.title("Búsqueda Inteligente")
        self.configure(bg=C["bg"])
        self.resizable(True, True)
        self.grab_set()
        self.db         = db
        self.on_success = on_success
        self.app_root   = app_root
        self._type_var  = tk.StringVar(value="")   # "" todos / "movie" / "series"
        self._build(initial_title)
        self._center()
        self.bind("<Escape>", lambda e: self.destroy())
        if initial_title:
            self.after(100, self._search)

    def _center(self):
        self.update_idletasks()
        w, h = 840, 660
        x = (self.winfo_screenwidth()  - w) // 2
        y = (self.winfo_screenheight() - h) // 2
        self.geometry(f"{w}x{h}+{x}+{y}")

    def _build(self, initial=""):
        main = tk.Frame(self, bg=C["bg"], padx=20, pady=16)
        main.pack(fill="both", expand=True)

        # Cabecera
        tk.Label(main, text="🔍 Búsqueda Inteligente", bg=C["bg"], fg=C["text"],
                 font=(FONT_FAMILY, 16, "bold")).pack(anchor="w")
        tk.Label(main, text="Busca en OMDb · TMDb · DuckDuckGo — todos los resultados, no solo el primero",
                 bg=C["bg"], fg=C["muted"], font=(FONT_FAMILY, 9)).pack(anchor="w", pady=(0, 8))

        # Barra de búsqueda
        bar = tk.Frame(main, bg=C["bg"])
        bar.pack(fill="x", pady=(0, 4))
        self._query_var = tk.StringVar(value=initial)
        self._entry = tk.Entry(bar, textvariable=self._query_var,
                               bg=C["surface"], fg=C["text"],
                               insertbackground=C["text"],
                               font=(FONT_FAMILY, 13), relief="flat")
        self._entry.pack(side="left", fill="x", expand=True, ipady=8)
        self._entry.focus()
        self._entry.bind("<Return>", lambda e: self._search())
        self._search_btn = tk.Button(bar, text="Buscar", bg=C["accent"], fg="white",
                                      font=(FONT_FAMILY, 11, "bold"), relief="flat",
                                      padx=14, pady=6, cursor="hand2",
                                      command=self._search)
        self._search_btn.pack(side="left", padx=(6, 0))

        # Filtro de tipo
        frow = tk.Frame(main, bg=C["bg"])
        frow.pack(fill="x", pady=(0, 6))
        tk.Label(frow, text="Filtrar por tipo:", bg=C["bg"], fg=C["muted"],
                 font=(FONT_FAMILY, 9)).pack(side="left", padx=(0, 10))
        for label, value, color in [
            ("Todos",        "",        C["muted"]),
            ("🎬 Películas", "movie",   C["movie_badge"]),
            ("📺 Series",    "series",  C["series_badge"]),
        ]:
            rb = tk.Radiobutton(frow, text=label, variable=self._type_var, value=value,
                                bg=C["bg"], fg=C["text"], selectcolor=C["surface"],
                                activebackground=C["bg"], activeforeground=C["text"],
                                font=(FONT_FAMILY, 10), cursor="hand2")
            rb.pack(side="left", padx=(0, 16))

        # Status
        self._status = tk.Label(main, text="", bg=C["bg"], fg=C["muted"],
                                 font=(FONT_FAMILY, 9), wraplength=780, anchor="w")
        self._status.pack(fill="x", pady=(0, 4))

        # Área de resultados scrollable
        container = tk.Frame(main, bg=C["bg"])
        container.pack(fill="both", expand=True)

        self._canvas = tk.Canvas(container, bg=C["bg"], highlightthickness=0)
        sb = tk.Scrollbar(container, orient="vertical", command=self._canvas.yview)
        self._canvas.configure(yscrollcommand=sb.set)
        sb.pack(side="right", fill="y")
        self._canvas.pack(side="left", fill="both", expand=True)

        self._result_frame = tk.Frame(self._canvas, bg=C["bg"])
        self._cwin = self._canvas.create_window((0, 0), window=self._result_frame, anchor="nw")
        self._result_frame.bind("<Configure>",
                                lambda e: self._canvas.configure(
                                    scrollregion=self._canvas.bbox("all")))
        self._canvas.bind("<Configure>",
                          lambda e: self._canvas.itemconfig(self._cwin, width=e.width))
        for w in (self._canvas, self._result_frame):
            w.bind("<MouseWheel>",
                   lambda e: self._canvas.yview_scroll(int(-1*(e.delta/120)), "units"))

    # ── Búsqueda ───────────────────────────────────────────────

    def _search(self):
        query = self._query_var.get().strip()
        if not query:
            return
        type_hint = self._type_var.get()
        self._search_btn.config(state="disabled", text="Buscando…")
        self._status.config(text="🔍 Consultando múltiples fuentes…", fg=C["muted"])
        for w in self._result_frame.winfo_children():
            w.destroy()

        def _worker():
            all_items  = []
            seen_lower = set()

            # OMDb multi-resultado
            for item in fetch_omdb_multi(query, type_hint):
                k = item["Title"].lower()
                if k not in seen_lower:
                    seen_lower.add(k)
                    all_items.append(item)

            # Si OMDb multi no devuelve nada, probar búsqueda exacta
            if not all_items and CFG.get("omdb_api_key"):
                exact = fetch_omdb(query)
                if exact:
                    exact["_source"] = "omdb"
                    k = exact.get("Title", "").lower()
                    if k not in seen_lower:
                        seen_lower.add(k)
                        all_items.append(exact)

            # TMDb multi-resultado
            for item in fetch_tmdb_multi(query, type_hint):
                k = item["Title"].lower()
                if k not in seen_lower:
                    seen_lower.add(k)
                    all_items.append(item)

            # DuckDuckGo (solo informativo, sin botón añadir)
            ddg      = fetch_duckduckgo(query)
            ddg_info = ddg if (ddg and ddg.get("abstract")) else None
            links    = build_external_links(query)

            self.after(0, lambda: self._show_results(query, all_items, ddg_info, links))

        threading.Thread(target=_worker, daemon=True).start()

    # ── Renderizado ────────────────────────────────────────────

    def _show_results(self, query: str, results: list, ddg_info, links: dict):
        try:
            self._search_btn.config(state="normal", text="Buscar")
        except Exception:
            return

        for w in self._result_frame.winfo_children():
            w.destroy()

        type_label = {"movie": " películas", "series": " series"}.get(
            self._type_var.get(), "")

        if results:
            self._status.config(
                text=f"✅ {len(results)} resultado(s){type_label} para «{query}»",
                fg=C["seen"])
        else:
            self._status.config(
                text=f"❌ Sin resultados{type_label} para «{query}». "
                     f"Prueba con otro filtro o añade manualmente abajo.",
                fg=C["accent"])

        for data in results:
            self._build_result_card(data)

        # ── DuckDuckGo — solo descripción informativa ──────────
        if ddg_info:
            tk.Frame(self._result_frame, bg=C["border"], height=1).pack(fill="x", pady=(8, 4))
            ddg_card = tk.Frame(self._result_frame, bg=C["surface"], padx=14, pady=8)
            ddg_card.pack(fill="x", pady=2)
            hdr = tk.Frame(ddg_card, bg=C["surface"])
            hdr.pack(fill="x")
            tk.Label(hdr, text="WEB", bg=C["web"], fg="white",
                     font=(FONT_FAMILY, 8, "bold"), padx=6, pady=2).pack(side="left", padx=(0,8))
            tk.Label(hdr, text="Descripción encontrada en la web",
                     bg=C["surface"], fg=C["muted"],
                     font=(FONT_FAMILY, 10, "italic")).pack(side="left")
            tk.Label(ddg_card, text=ddg_info.get("abstract","")[:300],
                     bg=C["surface"], fg=C["muted"], font=(FONT_FAMILY, 9),
                     wraplength=780, justify="left").pack(anchor="w", pady=(4, 0))

        # ── Añadir manual ──────────────────────────────────────
        tk.Frame(self._result_frame, bg=C["border"], height=1).pack(fill="x", pady=(14, 6))
        ext = tk.Frame(self._result_frame, bg=C["bg"])
        ext.pack(fill="x", padx=4)
        tk.Label(ext, text="¿Lo encontraste en Letterboxd, FilmAffinity u otra web? Añádelo aquí:",
                 bg=C["bg"], fg=C["muted"], font=(FONT_FAMILY, 9, "bold")).pack(anchor="w", pady=(0,6))
        mrow = tk.Frame(ext, bg=C["bg"])
        mrow.pack(fill="x")
