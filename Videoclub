    def _mark_all_watched(self):
        """Marca como vistos todos los ítems del filtro actual."""
        items = self._all_items
        if not items:
            return
        for item in items:
            self.db.set_status(self.active_user_id, item["title"], STATUS_WATCHED)
        show_toast(self, f"{len(items)} títulos marcados como vistos")
        self.refresh()

    def _mark_all_pending(self):
        """Marca como pendientes todos los ítems del filtro actual."""
        items = self._all_items
        if not items:
            return
        for item in items:
            self.db.set_status(self.active_user_id, item["title"], STATUS_PENDING)
        show_toast(self, f"{len(items)} títulos marcados como pendientes")
        self.refresh()

    def _clear_all_statuses(self):
        """Limpia el estado de todos los ítems del filtro actual."""
        items = self._all_items
        if not items:
            return
        if not messagebox.askyesno(
            "Limpiar estados",
            f"¿Quitar el estado de {len(items)} títulos?\n"
            "Quedarán como «Sin ver».",
            parent=self
        ):
            return
        for item in items:
            self.db.set_status(self.active_user_id, item["title"], STATUS_NONE)
        show_toast(self, f"{len(items)} estados limpiados", kind="warn")
        self.refresh()

    def _random_unseen(self):
        """Abre el detalle de un título aleatorio sin ver de la colección."""
        unseen = [i for i in self._all_items
                  if self._statuses.get(i["title"], STATUS_NONE) == STATUS_NONE]
        if not unseen:
            show_toast(self, "¡No quedan títulos sin ver!", kind="warn")
            return
        item = random.choice(unseen)
        DetailWindow(self, dict(item), self.active_user_id, self.db, self.refresh, self)

    def _goto_title(self):
        """Diálogo para buscar y abrir directamente un título de la biblioteca."""
        dlg = tk.Toplevel(self)
        dlg.title("Ir a título")
        dlg.configure(bg=C["bg"])
        dlg.resizable(False, False)
        dlg.grab_set()
        dlg.bind("<Escape>", lambda _: dlg.destroy())

        f = tk.Frame(dlg, bg=C["bg"], padx=20, pady=16)
        f.pack()
        tk.Label(f, text="Buscar en mi biblioteca:", bg=C["bg"], fg=C["muted"],
                 font=(FONT_FAMILY, 9)).pack(anchor="w", pady=(0, 4))

        var = tk.StringVar()
        entry = tk.Entry(f, textvariable=var, bg=C["surface"], fg=C["text"],
                         insertbackground=C["text"], relief="flat",
                         font=(FONT_FAMILY, 11), width=30)
        entry.pack(fill="x", ipady=6)
        entry.focus()

        res_frame = tk.Frame(f, bg=C["bg"])
        res_frame.pack(fill="x", pady=(6, 0))

        def _search(*_):
            for w in res_frame.winfo_children():
                w.destroy()
            q = var.get().strip().lower()
            if not q:
                return
            hits = [i for i in self._all_items if q in i["title"].lower()][:8]
            for item in hits:
                def _open(i=item):
                    dlg.destroy()
                    DetailWindow(self, dict(i), self.active_user_id,
                                 self.db, self.refresh, self)
                tk.Button(res_frame, text=item["title"],
                          bg=C["surface"], fg=C["text"],
                          font=(FONT_FAMILY, 10), relief="flat",
                          anchor="w", padx=8, pady=5, cursor="hand2",
                          command=_open).pack(fill="x", pady=1)

        var.trace_add("write", _search)

        dlg.update_idletasks()
        x = (dlg.winfo_screenwidth()  - dlg.winfo_width())  // 2
        y = (dlg.winfo_screenheight() - dlg.winfo_height()) // 2
        dlg.geometry(f"+{x}+{y}")

    def _open_refresh_meta(self):
        RefreshMetaDialog(self, self.db, self.active_user_id, self.refresh, self)

    def _set_filter(self, ftype: str):
        self.filter_type.set(ftype)
        self._fill_toolbar()
        self._reset_page()

    def _set_status_filter(self, val: str):
        self.status_filter.set(val)
        self._fill_toolbar()
        self._reset_page()

    def _set_sort(self, order: str):
        self.sort_order.set(order)
        self._fill_toolbar()
        self._reset_page()

    def set_genre_filter(self, genre: str):
        self.genre_filter.set(genre)
        self._fill_toolbar()
        self._reset_page()

    def _clear_genre_filter(self):
        self.genre_filter.set("")
        self._fill_toolbar()
        self._reset_page()

    def _on_close(self):
        log.info("Cerrando app.")
        _stop_event.set()
        _poster_pool.shutdown(wait=False)
        _season_pool.shutdown(wait=False)
        self.db.close()
        self.destroy()


