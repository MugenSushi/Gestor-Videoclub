                     wraplength=780, justify="left"
                     ).pack(anchor="w", pady=(4, 0))

    # ── Acciones ───────────────────────────────────────────────

    def _add_result(self, data: dict):
        title = data.get("Title", "")
        if not title:
            return
        uid = self.app_root.active_user_id
        if self.db.item_exists(title, uid):
            self._status.config(text=f'⚠️ "{title}" ya está en la biblioteca.', fg=C["pending"])
            return

        # Enriquecer: OMDb detail si solo tenemos ID, TMDb detail para créditos/streaming
        imdb_id = data.get("_imdbID", "")
        if imdb_id and not data.get("Plot"):
            detail = fetch_omdb_detail(imdb_id)
            if detail:
                data.update({k: v for k, v in detail.items() if v and v != "N/A"})

        tmdb_id = data.get("_tmdb_id", "")
        if tmdb_id and not data.get("Director"):
            itype_hint = "movie" if data.get("Type", "movie") == "movie" else "tv"
            extra = fetch_tmdb_detail(tmdb_id, itype_hint)
            if extra:
                data.update({k: v for k, v in extra.items() if v})

        itype = detect_type(data)
        try:
            rating = float(data.get("imdbRating") or 0) or None
        except ValueError:
            rating = None

        poster_url = data.get("Poster", "")
        if poster_url in ("N/A", ""):
            poster_url = ""

        def _cache():
            if poster_url:
                path = safe_filename(title)
                if not path.exists():
                    try:
                        resp = requests.get(poster_url, timeout=12, stream=True)
                        Image.open(resp.raw).convert("RGB").save(path)
                    except Exception as e:
                        log.warning(f"Cache poster: {e}")
        threading.Thread(target=_cache, daemon=True).start()

        extra = _extract_extra(data)
        ok = self.db.add_item(
            title, itype, rating,
            data.get("Genre", "") or "",
            data.get("Year", "") or "",
            data.get("Plot", "") or "",
            poster_url,
            tmdb_id=data.get("_tmdb_id", ""),
            num_seasons=data.get("_num_seasons", 0),
            user_id=uid,
            **extra
        )
        if ok:
            self._status.config(
                text=f'✅ "{title}" añadido como {itype}.',
                fg=C["seen"]
            )
            btn = data.get("_btn")
            if btn and btn.winfo_exists():
                btn.config(text="✅ En biblioteca", bg=C["border"], state="disabled")
            show_toast(self.app_root, f'"{title}" añadido a la biblioteca')
            self.on_success()
        else:
            self._status.config(text=f'⚠️ Error al añadir "{title}".', fg=C["accent"])
            show_toast(self.app_root, f'Error al añadir "{title}"', kind="error")

    def _add_manual(self):
        """Añade desde plataforma externa: busca metadata y fuerza el tipo elegido."""
        title = self._manual_title.get().strip()
        if not title:
            self._status.config(text="⚠️ Escribe un título.", fg=C["pending"])
            return
        uid = self.app_root.active_user_id
        if self.db.item_exists(title, uid):
            self._status.config(text=f'⚠️ "{title}" ya está en la biblioteca.', fg=C["pending"])
            return

        itype_forced = self._manual_type.get()
        self._status.config(text=f"🔍 Buscando metadata para «{title}»…", fg=C["muted"])

        def _worker():
            data = smart_search(title)
            data["Type"] = itype_forced        # respetar el tipo que eligió el usuario
            data["Title"] = data.get("Title") or title

            # Inject _tmdb_id for series — smart_search/fetch_tmdb does not return _tmdb_id
            # (fetch_tmdb_multi does). Needed so _finish_manual can persist tmdb_id.
            if (itype_forced == "series"
                    and data.get("_source") == "tmdb"
                    and CFG.get("tmdb_api_key")):
                candidates = fetch_tmdb_multi(title, type_hint="series")
                if candidates:
                    data["_tmdb_id"] = candidates[0].get("_tmdb_id", "")

            self.after(0, lambda: self._finish_manual(data, itype_forced))

        threading.Thread(target=_worker, daemon=True).start()

    def _finish_manual(self, data: dict, itype_forced: str):
        title = data.get("Title", "")
        if not title:
            return
        try:
            rating = float(data.get("imdbRating") or 0) or None
        except ValueError:
            rating = None

        poster_url = data.get("Poster", "")
        if poster_url in ("N/A", ""):
            poster_url = ""

        def _cache():
            if poster_url:
                path = safe_filename(title)
                if not path.exists():
                    try:
                        resp = requests.get(poster_url, timeout=12, stream=True)
                        Image.open(resp.raw).convert("RGB").save(path)
                    except Exception as e:
                        log.warning(f"Cache poster: {e}")
        threading.Thread(target=_cache, daemon=True).start()

        extra = _extract_extra(data)
        ok = self.db.add_item(
            title, itype_forced, rating,
            data.get("Genre", "") or "",
            data.get("Year", "") or "",
            data.get("Plot", "") or "",
            poster_url,
            tmdb_id=data.get("_tmdb_id", ""),
            num_seasons=data.get("_num_seasons", 0),
            user_id=self.app_root.active_user_id,
            **extra
        )
        if ok:
            src = data.get("_source", "manual")
            self._status.config(
                text=f'✅ "{title}" añadido como {itype_forced} (fuente: {src}).',
                fg=C["seen"]
            )
            show_toast(self.app_root, f'"{title}" añadido a la biblioteca')
            self.on_success()
        else:
            self._status.config(text=f'⚠️ Error al añadir "{title}".', fg=C["accent"])
            show_toast(self.app_root, f'Error al añadir "{title}"', kind="error")


