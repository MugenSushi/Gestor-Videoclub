        if studio    and studio    != "N/A": meta2.append(f"🏭 {studio}")
        if streaming and streaming != "N/A": meta2.append(f"▶ {streaming}")
        if meta2:
            tk.Label(card, text="  ·  ".join(meta2),
                     bg=C["surface"], fg=C["accent2"], font=(FONT_FAMILY, 9)
                     ).pack(anchor="w", pady=(2, 0))

