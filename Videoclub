class RefreshMetaDialog(tk.Toplevel):
    """Actualiza director, actores, estudio y streaming de títulos antiguos
    que no tienen esos campos rellenados todavía."""

    def __init__(self, parent, db: Database, user_id: int, on_done, app_root):
        super().__init__(parent)
        self.title("Actualizar metadata")
        self.configure(bg=C["bg"])
        self.resizable(False, False)
        self.grab_set()
        self.db       = db
        self.user_id  = user_id
        self.on_done  = on_done
        self.app_root = app_root
        self._stop    = threading.Event()
        self._build()
        self._center()
        self.protocol("WM_DELETE_WINDOW", self._cancel)
        self.bind("<Escape>", lambda _: self._cancel())

    def _center(self):
        self.update_idletasks()
        x = (self.winfo_screenwidth()  - self.winfo_width())  // 2
        y = (self.winfo_screenheight() - self.winfo_height()) // 2
        self.geometry(f"+{x}+{y}")

    def _build(self):
        f = tk.Frame(self, bg=C["bg"], padx=28, pady=20)
        f.pack(fill="both", expand=True)

        tk.Label(f, text="🔄 Actualizar metadata", bg=C["bg"], fg=C["text"],
                 font=(FONT_FAMILY, 14, "bold")).pack(anchor="w", pady=(0, 4))

        pending = self.db.get_items_missing_meta(self.user_id)
        self._total = len(pending)

        if self._total == 0:
            tk.Label(f, text="✅ Todos los títulos ya tienen metadata completa.",
                     bg=C["bg"], fg=C["seen"],
                     font=(FONT_FAMILY, 10)).pack(anchor="w", pady=8)
            tk.Button(f, text="Cerrar", bg=C["surface"], fg=C["text"],
                      font=(FONT_FAMILY, 10), relief="flat",
                      padx=14, pady=5, cursor="hand2",
                      command=self.destroy).pack(anchor="e", pady=(8, 0))
            return

        tk.Label(f,
                 text=f"{self._total} títulos sin director/actores/estudio/streaming.\n"
                      "Se buscará en OMDb y TMDb para rellenar los campos vacíos.",
                 bg=C["bg"], fg=C["muted"],
                 font=(FONT_FAMILY, 9), wraplength=480,
                 justify="left").pack(anchor="w", pady=(0, 12))

        # Barra de progreso
        style = ttk.Style()
        style.theme_use("default")
        style.configure("RM.Horizontal.TProgressbar",
                         troughcolor=C["border"], background=C["seen"],
                         bordercolor=C["border"],
                         lightcolor=C["seen"], darkcolor=C["seen"])
        self._bar = ttk.Progressbar(f, style="RM.Horizontal.TProgressbar",
                                     orient="horizontal", length=480,
                                     mode="determinate", maximum=self._total)
        self._bar.pack(fill="x", pady=(0, 6))

        self._lbl = tk.Label(f, text="Preparando…", bg=C["bg"], fg=C["muted"],
                              font=(FONT_FAMILY, 9), anchor="w")
        self._lbl.pack(fill="x")

        self._count_lbl = tk.Label(f, text=f"0 / {self._total}", bg=C["bg"],
                                    fg=C["text"], font=(FONT_FAMILY, 9))
        self._count_lbl.pack(anchor="e")

        bf = tk.Frame(f, bg=C["bg"])
        bf.pack(fill="x", pady=(14, 0))
        self._start_btn = tk.Button(bf, text="▶ Iniciar", bg=C["seen"], fg="white",
                                     font=(FONT_FAMILY, 11, "bold"), relief="flat",
                                     padx=16, pady=6, cursor="hand2",
                                     command=lambda: self._start(pending))
        self._start_btn.pack(side="left")
        tk.Button(bf, text="Cancelar", bg=C["surface"], fg=C["muted"],
                  font=(FONT_FAMILY, 10), relief="flat",
                  padx=12, pady=5, cursor="hand2",
                  command=self._cancel).pack(side="left", padx=(8, 0))

    def _start(self, pending: list):
        self._start_btn.config(state="disabled", text="Actualizando…")
        self._stop.clear()
        threading.Thread(target=self._worker, args=(pending,), daemon=True).start()

    def _worker(self, pending: list):
        updated = 0
        for idx, item in enumerate(pending, 1):
            if self._stop.is_set():
                break
            title = item["title"]
            self.after(0, lambda t=title, i=idx: self._update_ui(t, i))

            # Intentar OMDb primero, luego TMDb
            data = {}
            if CFG.get("omdb_api_key"):
                data = fetch_omdb(title) or {}
            if not data.get("Director") and CFG.get("tmdb_api_key"):
                tmdb = fetch_tmdb(title)
                tid  = tmdb.get("_tmdb_id", "")
                mt   = "tv" if tmdb.get("Type") == "series" else "movie"
                if tid:
                    data.update(fetch_tmdb_detail(tid, mt))

            director  = (data.get("Director") or "").strip()
            actors    = (data.get("Actors")   or "").strip()
            studio    = (data.get("Studio")   or data.get("Production") or "").strip()
            streaming = (data.get("Streaming") or "").strip()
            plot      = (data.get("Plot")     or "").strip()

            if any([director, actors, studio, streaming, plot]):
                self.db.update_meta(title, director, actors, studio, streaming, plot)
                updated += 1

        self.after(0, lambda: self._done(updated))

    def _update_ui(self, title: str, idx: int):
        if not self.winfo_exists():
            return
        short = title[:45] + "…" if len(title) > 45 else title
        self._lbl.config(text=f"🔍 {short}")
        self._bar["value"] = idx
        self._count_lbl.config(text=f"{idx} / {self._total}")

    def _done(self, updated: int):
        if not self.winfo_exists():
            return
        self._lbl.config(text=f"✅ Completado — {updated} títulos actualizados.",
                          fg=C["seen"])
        self._start_btn.config(state="disabled")
        show_toast(self.app_root, f"{updated} títulos actualizados")
        self.on_done()

    def _cancel(self):
        self._stop.set()
        self.destroy()


