        y = (self.winfo_screenheight() - 520) // 2
        self.geometry(f"600x520+{x}+{y}")

    def _build(self):
        f = tk.Frame(self, bg=C["bg"], padx=22, pady=18)
        f.pack(fill="both", expand=True)

        tk.Label(f, text="📋 Importar lista de títulos", bg=C["bg"], fg=C["text"],
