        sb.pack(side="right", fill="y")
        self.text.config(yscrollcommand=sb.set)

        # Barra de progreso real con ttk.Progressbar
        style = ttk.Style()
        style.theme_use("default")
        style.configure("VC.Horizontal.TProgressbar",
                         troughcolor=C["border"], background=C["accent"],
                         bordercolor=C["border"], lightcolor=C["accent"],
                         darkcolor=C["accent"])
        self._progressbar = ttk.Progressbar(
            f, style="VC.Horizontal.TProgressbar",
            orient="horizontal", length=540, mode="determinate"
        )
        self._progressbar.pack(fill="x", pady=(6, 0))
        self._progressbar["maximum"] = 100
        self._progressbar["value"]   = 0

        self.progress_lbl = tk.Label(f, text="", bg=C["bg"], fg=C["muted"],
                                      font=(FONT_FAMILY, 9), wraplength=550)
        self.progress_lbl.pack(pady=(4, 0))

        # Botones
        bf = tk.Frame(f, bg=C["bg"])
        bf.pack(pady=(10, 0), fill="x")

        tk.Button(bf, text="📂 Cargar archivo", bg=C["surface"], fg=C["text"],
                  font=(FONT_FAMILY, 10), relief="flat", padx=12, pady=5,
                  cursor="hand2", command=self._load_file).pack(side="left")

        self.import_btn = tk.Button(
            bf, text="▶ Importar todo", bg=C["accent"], fg="white",
            font=(FONT_FAMILY, 10, "bold"), relief="flat",
            padx=14, pady=5, cursor="hand2", command=self._start_import
        )
        self.import_btn.pack(side="right")
        tk.Button(bf, text="Cerrar", bg=C["border"], fg=C["text"],
                  font=(FONT_FAMILY, 10), relief="flat", padx=12, pady=5,
                  cursor="hand2", command=self.destroy).pack(side="right", padx=6)

    def _load_file(self):
        path = filedialog.askopenfilename(
            title="Abrir lista",
            filetypes=[("Texto/CSV", "*.txt *.csv"), ("Todos", "*.*")]
        )
        if path:
            try:
                content = Path(path).read_text(encoding="utf-8", errors="ignore")
                self.text.delete("1.0", "end")
                self.text.insert("1.0", content)
            except Exception as e:
                log.error(f"Batch load: {e}")

    def _start_import(self):
        if self._running:
            return
        raw = self.text.get("1.0", "end").strip()
        if not raw:
            return

        uid      = self.app_root.active_user_id
        existing = self.db.batch_titles(uid)
        titles_all = []
        for line in raw.splitlines():
            t = line.strip().strip(",;").strip()
            if t and t.lower() not in existing:
                titles_all.append(t)

        if not titles_all:
            self.progress_lbl.config(
                text="✅ Todos los títulos ya existen en la biblioteca.",
                fg=C["seen"]
            )
            return

        self._running = True
        self.import_btn.config(state="disabled", text="Importando…")
        self._progressbar["value"] = 0

        def _worker():
            total   = len(titles_all)
            added   = 0
            failed  = []

            for i, title in enumerate(titles_all, 1):
                if _stop_event.is_set():
                    break

                data = smart_search(title)
                # smart_search ahora siempre devuelve dict con Title (fallback manual)
                real_title = data.get("Title") or title
                itype = detect_type(data)
                try:
                    rating = float(data.get("imdbRating") or 0) or None
                except (ValueError, TypeError):
                    rating = None

                ok = self.db.add_item(
                    real_title, itype, rating,
                    data.get("Genre", ""),
                    data.get("Year", ""),
                    data.get("Plot", ""),
                    data.get("Poster", ""),
                    user_id=uid, **_extract_extra(data)
                )
                if ok:
                    added += 1
                    # BUG3 FIX: eliminar usando el título ORIGINAL buscado
                    # (no real_title que puede diferir por capitalización de OMDb)
                    self.after(0, lambda t=title, rt=real_title:
                               self._remove_line(t, rt))
                else:
                    failed.append(title)

                pct = int(i / total * 100)
                msg = f"[{i}/{total}]  {title[:45]}"
                self.after(0, lambda m=msg, p=pct: self._update_progress(m, p))

            self.after(0, lambda: self._import_done(added, failed))

        threading.Thread(target=_worker, daemon=True).start()

    def _remove_line(self, original_title: str, real_title: str = ""):
        """
        BUG3 FIX: Elimina la línea del título del text widget.
        Intenta eliminar por título original Y por título real (pueden diferir).
        """
        try:
            content = self.text.get("1.0", "end")
            lines = content.splitlines()
            filtered = []
            for line in lines:
                stripped = line.strip().strip(",;").strip().lower()
                if stripped == original_title.lower():
                    continue
                if real_title and stripped == real_title.lower():
                    continue
                filtered.append(line)
            # Solo reescribir si realmente cambió algo
            if len(filtered) < len(lines):
                self.text.delete("1.0", "end")
                self.text.insert("1.0", "\n".join(filtered))
        except Exception as e:
            log.error(f"_remove_line: {e}")

    def _update_progress(self, msg: str, pct: int):
        try:
            self.progress_lbl.config(text=msg, fg=C["muted"])
            self._progressbar["value"] = pct
        except Exception:
            pass

    def _import_done(self, added: int, failed: list):
        self._running = False
        try:
            if failed:
                self.progress_lbl.config(
                    text=f"✅ {added} añadidos.  "
                         f"❌ {len(failed)} no encontrados (quedan en la lista).",
                    fg=C["text"]
                )
            else:
                self.progress_lbl.config(
                    text=f"✅ {added} títulos añadidos. ¡Lista completada!",
                    fg=C["seen"]
                )
            self.import_btn.config(state="normal", text="▶ Importar todo")
            self.on_success()
        except Exception:
            pass


