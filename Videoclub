# 8. STAR RATING WIDGET
# ══════════════════════════════════════════════════════════════

class StarRating(tk.Frame):
    def __init__(self, parent, initial=0, on_change=None, size=14, **kw):
        super().__init__(parent, bg=kw.pop("bg", C["bg"]), **kw)
        self._stars = []
        self._value = initial
        self._cb    = on_change
        for i in range(1, 6):
            lbl = tk.Label(self, text="★", bg=self["bg"],
                           font=(FONT_FAMILY, size), cursor="hand2")
            lbl.pack(side="left")
            lbl.bind("<Button-1>", lambda e, v=i: self._click(v))
            lbl.bind("<Enter>",    lambda e, v=i: self._draw(v))
            lbl.bind("<Leave>",    lambda e:      self._draw(self._value))
            self._stars.append(lbl)
        self._draw(initial)

    def _click(self, v):
        self._value = 0 if self._value == v else v
        self._draw(self._value)
        if self._cb:
            self._cb(self._value)

    def _draw(self, v):
        for i, lbl in enumerate(self._stars):
            lbl.config(fg=C["star_on"] if i < v else C["star_off"])

    @property
    def value(self):
        return self._value

    def set(self, v):
        self._value = v
        self._draw(v)


