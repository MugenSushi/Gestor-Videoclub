    def _update_statusbar_counters(self):
        """Actualiza los contadores de vistos/pendientes/sin ver en la barra de estado."""
        items = self._all_items
        n_seen    = sum(1 for i in items if self._statuses.get(i["title"], STATUS_NONE) == STATUS_WATCHED)
        n_pending = sum(1 for i in items if self._statuses.get(i["title"], STATUS_NONE) == STATUS_PENDING)
        n_unseen  = len(items) - n_seen - n_pending
        if hasattr(self, "_sb_seen_lbl"):
            self._sb_seen_lbl.config(text=f"✓ {n_seen}")
            self._sb_pending_lbl.config(text=f"⏳ {n_pending}")
            self._sb_unseen_lbl.config(text=f"○ {n_unseen}")

    def _on_canvas_resize(self, event):
        self.canvas.itemconfig(self._win_id, width=event.width)
        new_cols = max(MIN_COLUMNS, event.width // (CARD_W + CARD_GRID_PAD * 2))
        if new_cols != self._columns and self._all_items:
            self._columns = new_cols
            for w in self.grid_frame.winfo_children():
                w.destroy()
            self._cards.clear()
            self._render_page()

